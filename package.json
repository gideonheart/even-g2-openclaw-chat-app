{
  "name": "even-g2-openclaw-chat-app",
  "version": "0.1.0",
  "type": "module",
  "description": "EvenHub companion app for Even G2 ↔ OpenClaw voice interactions",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pack": "npm run build && evenhub pack app.json dist -o openclaw-chat.ehpk"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.5",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.7"
  }
}
